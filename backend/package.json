{
  "name": "yasrun-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "lint": "eslint 'functions/**/*.js' 'layers/**/*.js'",
    "test": "jest --coverage",
    "dev": "node --watch local/server.js",
    "setup:local": "node local/setup-db.js",
    "start:local": "npm run setup:local && npm run dev",
    "deploy:layers": "bash scripts/deploy-layers.sh",
    "deploy:functions": "bash scripts/deploy-functions.sh"
  },
  "workspaces": [
    "functions/*",
    "layers/*"
  ],
  "jest": {
    "testMatch": ["**/tests/**/*.test.js"],
    "testPathIgnorePatterns": ["/tests/integration/"],
    "coverageDirectory": "coverage",
    "collectCoverageFrom": ["layers/**/*.js", "functions/**/*.js"]
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.600.0",
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/client-secrets-manager": "^3.600.0",
    "@aws-sdk/lib-dynamodb": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  }
}
