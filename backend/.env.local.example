# ローカル開発用環境変数
# このファイルをコピーして使う: cp .env.local.example .env.local

DYNAMODB_TABLE=yasrun
DYNAMODB_ENDPOINT=http://localhost:8000
S3_BUCKET=yasrun-images
S3_ENDPOINT=http://localhost:4566
AWS_REGION=ap-northeast-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# JWT (ローカル開発用。本番はSecrets Managerで管理)
JWT_SECRET=local-dev-jwt-secret-change-in-production

# Gemini API Key (実際のキーを設定するとAI機能が動く。未設定でもモックで動く)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

PORT=3000
NODE_ENV=development

# IAP モック (true にすると Apple/Google への実際のリクエストをスキップしてローカルで premium テスト可能)
IAP_MOCK=true

# 管理画面ログイン
# ADMIN_PASSWORD_HASH は bcryptjs で生成: node -e "require('bcryptjs').hash('パスワード',10).then(console.log)"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
